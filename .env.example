# Supabase public client env.
# Copy/fill values in the shared local file:
# /Users/kangsungbae/.config/sungbae/shared-env/supabase-public.env.local

VITE_SUPABASE_URL=
VITE_SUPABASE_ANON_KEY=

# Release/public policy placeholders.
# These are public URLs/contact values, not secrets.
PUBLIC_PRIVACY_URL=
PUBLIC_CONTACT_EMAIL=
PUBLIC_DATA_DELETION_URL=

# Apps in Toss Console API key is agent/CI/server-only.
# Do not expose it through VITE_, NEXT_PUBLIC_, or PUBLIC_ prefixes.
APPS_IN_TOSS_CONSOLE_API_KEY=

# Server-only AI secrets.
# Actual local values are shared through:
# /Users/kangsungbae/.config/sungbae/shared-env/ai-secrets.env.local
# Never expose these through VITE_, NEXT_PUBLIC_, or PUBLIC_ variables.
AI_COPY_ENABLED=false
AI_COORDINATION_ENABLED=false
AI_PROVIDER=deepseek
AI_MODEL_COPY=deepseek-v4-pro
AI_MODEL_COORDINATION=deepseek-v4-pro
AI_MODEL_SAFETY=deepseek-v4-pro
DEEPSEEK_API_KEY=

# Server-only backend connection secrets.
# Keep real values in shared admin/server env or Supabase function secrets only.
HAMMOYEO_DB_ADMIN_KEY=
SUPABASE_SECRET_KEY=
HAMMOYEO_SESSION_SECRET=
HAMMOYEO_PROVIDER_HASH_SECRET=
TOSS_AUTH_EXCHANGE_URL=
